{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Expense Tracker",
            "type": "shell",
            "command": "C:/MinGW/bin/g++.exe",
            "args": [
                "-g",
                "main.cpp",
                "Source_Code/Expense_Manage.cpp",
                "Source_Code/Transaction.cpp",
                "Source_Code/File_Manage.cpp",
                "-o",
                "main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}